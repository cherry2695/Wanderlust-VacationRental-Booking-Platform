<% layout("/layouts/boilerplate") %>
<body>
  <div class="row mt-4 mb-5">
    <div class="col-12 col-md-10 offset-md-1 col-lg-8 offset-lg-2">
      <!-- Back Button -->
      <div class="mb-3">
        <a href="/listings" class="btn btn-outline-custom btn-sm">
          <i class="fa-solid fa-chevron-left me-1"></i> Back to listings
        </a>
      </div>

      <!-- Form Card -->
      <div class="card form-card">
        <h3 class="form-title text-center mb-4">Create a New Listing</h3>

        <form
          method="POST"
          action="/listings"
          enctype="multipart/form-data"
          novalidate
          class="needs-validation"
        >
          <!-- TITLE -->
          <div class="form-floating mb-3">
            <input
              id="title"
              name="listing[title]"
              placeholder="Add a catchy title"
              type="text"
              class="form-control"
              required
            />
            <label for="title">Title</label>
            <div class="valid-feedback">Title looks good!</div>
            <div class="invalid-feedback">Please enter a catchy title.</div>
          </div>

          <!-- DESCRIPTION -->
          <div class="form-floating mb-3">
            <textarea
              id="description"
              name="listing[description]"
              class="form-control"
              placeholder="Detailed description"
              style="height: 150px;"
              required
            ></textarea>
            <label for="description">Description</label>
            <div class="invalid-feedback">Please enter a short description.</div>
          </div>

          <!-- IMAGE UPLOAD -->
          <div class="mb-3">
            <label for="image" class="form-label fw-bold" style="font-size: 0.9rem;">Upload Listing Image</label>
            <input
              id="image"
              name="listing[image]"
              type="file"
              class="form-control"
              accept="image/*"
              required
            />
            <div class="invalid-feedback">Please upload a valid image file.</div>
          </div>

          <!-- PRICE + CATEGORY -->
          <div class="row">
            <!-- PRICE -->
            <div class="col-md-6 mb-3">
              <div class="form-floating">
                <input
                  id="price"
                  name="listing[price]"
                  placeholder="Price per night"
                  type="number"
                  class="form-control"
                  min="0"
                  required
                />
                <label for="price">Price per night (₹)</label>
                <div class="invalid-feedback">Please enter a valid price.</div>
              </div>
            </div>

            <!-- CATEGORY -->
            <div class="col-md-6 mb-3">
              <div class="form-floating">
                <select
                  id="category"
                  name="listing[category]"
                  class="form-select"
                  required
                >
                  <option value="" disabled selected>Select Category</option>
                  <option value="Trending">Trending</option>
                  <option value="Rooms">Rooms</option>
                  <option value="Iconic Cities">Iconic City</option>
                  <option value="Mountains">Mountains</option>
                </select>
                <label for="category">Category</label>
                <div class="invalid-feedback">Please select a category.</div>
              </div>
            </div>
          </div>

          <!-- LOCATION + COUNTRY -->
          <div class="row">
            <!-- LOCATION -->
            <div class="col-md-6 mb-3">
              <div class="form-floating">
                <input
                  id="location"
                  name="listing[location]"
                  placeholder="City, State"
                  type="text"
                  class="form-control"
                  required
                />
                <label for="location">Location</label>
                <div class="invalid-feedback">Please enter a location.</div>
              </div>
            </div>

            <!-- COUNTRY -->
            <div class="col-md-6 mb-3">
              <div class="form-floating">
                <input
                  id="country"
                  name="listing[country]"
                  placeholder="Country"
                  type="text"
                  class="form-control"
                  required
                />
                <label for="country">Country</label>
                <div class="invalid-feedback">Please enter a country.</div>
              </div>
            </div>
          </div>

          <!-- AMENITIES -->
          <div class="mb-3">
            <label class="form-label fw-bold" style="font-size: 0.95rem;">Select Amenities</label>
            <div class="row g-2 mt-2">
              <% const amenityOptions = [
                ['wifi','High-speed Wi-Fi','fa-wifi'],
                ['kitchen','Kitchen','fa-utensils'],
                ['parking','Parking','fa-square-parking'],
                ['air_conditioning','Air conditioning','fa-snowflake'],
                ['pool','Pool','fa-swimming-pool'],
                ['bbq','BBQ grill','fa-burger'],
                ['workspace','Workspace','fa-laptop'],
                ['pet_friendly','Pet friendly','fa-paw'],
                ['fireplace','Fireplace','fa-fire']
              ]; %>
              <% amenityOptions.forEach(function(opt){ %>
                <div class="col-6 col-md-4">
                  <label class="form-check d-flex align-items-center gap-2">
                    <input class="form-check-input" type="checkbox" name="listing[amenities][]" value="<%= opt[0] %>">
                    <i class="fa-solid <%= opt[2] %> text-muted"></i>
                    <span><%= opt[1] %></span>
                  </label>
                </div>
              <% }); %>
            </div>
          </div>

          <!-- SUBMIT BUTTON -->
          <div class="d-grid mt-4">
            <button class="btn btn-primary-gradient py-3">
              Create Listing
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</body>
<script>
  (function(){
    const suggestions = {
      Mountains: ['fireplace','hiking','valley_view','hot_water'],
      'Iconic Cities': ['elevator','workspace','smart_tv','air_conditioning'],
      Beach: ['ocean_view','pool','bbq'],
      Rooms: ['wifi','kitchen','air_conditioning'],
      Trending: ['wifi','kitchen','parking']
    };

    const categoryEl = document.getElementById('category');
    const checkboxes = () => Array.from(document.querySelectorAll('input[name="listing[amenities][]"]'));

    if (categoryEl) {
      categoryEl.addEventListener('change', function(){
        const val = categoryEl.value;
        const rec = suggestions[val] || [];
        // only auto check if user hasn't manually selected any
        const anyChecked = checkboxes().some(cb => cb.checked);
        if (!anyChecked) {
          checkboxes().forEach(cb => {
            cb.checked = rec.includes(cb.value);
          });
        }
      });
    }
  })();
</script>