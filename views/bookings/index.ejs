<% layout('/layouts/boilerplate') %>

<div class="row mt-5 mb-5">
  <div class="col-12">
    <h2 class="fw-bold mb-3">My Bookings</h2>
    <% if (bookings.length === 0) { %>
      <div class="alert alert-light border">You have no bookings yet. Reserve a stay to see it here.</div>
    <% } %>
    <div class="row row-cols-1 g-4">
      <% for (let booking of bookings) { %>
        <div class="col">
          <div class="card booking-summary-card p-4">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <div>
                <h4 class="mb-1"><%= booking.listingTitle %></h4>
                <p class="text-muted mb-0"><%= booking.listingLocation %></p>
              </div>
              <span class="badge bg-<%= booking.status === 'confirmed' ? 'success' : 'warning' %>">
                <%= booking.status === 'confirmed' ? 'Confirmed' : 'Pending' %>
              </span>
            </div>
            <div class="row gx-3 gy-2 align-items-center mb-3">
              <div class="col-sm-6 col-lg-3">
                <span class="booking-summary-label">Check-in</span>
                <p class="booking-summary-value"><%= new Date(booking.checkIn).toLocaleDateString('en-CA') %></p>
              </div>
              <div class="col-sm-6 col-lg-3">
                <span class="booking-summary-label">Check-out</span>
                <p class="booking-summary-value"><%= new Date(booking.checkOut).toLocaleDateString('en-CA') %></p>
              </div>
              <div class="col-sm-6 col-lg-2">
                <span class="booking-summary-label">Guests</span>
                <p class="booking-summary-value"><%= booking.guests %></p>
              </div>
              <div class="col-sm-6 col-lg-4 text-lg-end">
                <span class="booking-summary-label">Total</span>
                <p class="booking-summary-value fw-bold">&#8377;<%= booking.totalPrice.toLocaleString('en-IN') %></p>
              </div>
            </div>
            <div class="d-flex flex-wrap gap-2">
              <a href="/listings/<%= booking.listing %>" class="btn btn-outline-custom btn-sm">View Listing</a>
              <% if (booking.status === 'pending') { %>
                <a href="/bookings/<%= booking._id %>/payment" class="btn btn-primary-gradient btn-sm">Complete Payment</a>
              <% } %>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</div>
