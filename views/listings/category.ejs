<% layout("/layouts/boilerplate") %>
<body>
  <!-- Reusable categories filter partial -->
  <%- include("../includes/categories.ejs") %>

  <!-- Listings Grid -->
  <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4 mt-1 mb-5">
    <% for(let listing of allListings) { %>
      <div class="col">
        <a href="/listings/<%= listing._id %>" class="listing-link">
          <div class="card listing-card h-100">
            <!-- Image container -->
            <div class="card-img-container">
              <img
                src="<%= optimizeCloudinary(listing.image.url, 520) %>"
                alt="<%= listing.title %>"
                loading="lazy"
                decoding="async"
                width="520"
                height="520"
              />
              <!-- Category Badge -->
              <% if (listing.category) { %>
                <span class="card-category-badge"><%= listing.category %></span>
              <% } %>
            </div>

            <!-- Card Body Details -->
            <div class="card-body card-body-custom">
              <!-- Title and rating -->
              <div class="card-title-row">
                <h3 class="card-title-text"><%= listing.title %></h3>
                <div class="card-rating-text">
                  <i class="fa-solid fa-star"></i>
                  <% if (listing.reviews && listing.reviews.length > 0) { %>
                    <% 
                      let total = 0;
                      for (let r of listing.reviews) {
                        if(r.rating) total += r.rating;
                      }
                      let avg = (total / listing.reviews.length).toFixed(1);
                    %>
                    <%= avg %>
                  <% } else { %>
                    New
                  <% } %>
                </div>
              </div>

              <!-- Location -->
              <div class="card-location-text">
                <%= listing.location %>, <%= listing.country %>
              </div>

              <!-- Price / Night -->
              <div class="card-price-row">
                <span class="card-price-num">&#8377;<%= listing.price.toLocaleString("en-IN") %></span> / night
                <span class="tax-info d-none">&nbsp;&nbsp;+18% GST</span>
              </div>
            </div>
          </div>
        </a>
      </div>
    <% } %>
  </div>
</body>

<!-- Tax Toggle JS script -->
<script>
  let taxSwitch = document.getElementById("taxSwitch");
  taxSwitch.addEventListener("change", () => {
    let taxInfo = document.getElementsByClassName("tax-info");
    for (let info of taxInfo) {
      if (taxSwitch.checked) {
        info.classList.remove("d-none");
      } else {
        info.classList.add("d-none");
      }
    }
  });
</script>